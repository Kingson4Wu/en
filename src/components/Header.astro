---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/en/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/en/blog">Blog</HeaderLink>
			<HeaderLink href="/en/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg);
		border-bottom: 1px solid var(--border);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a {
		text-decoration: none;
		font-family: 'Lora', Georgia, serif;
		font-size: 14px;
		font-weight: 700;
		color: var(--heading);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--muted);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 12px;
		letter-spacing: 0.04em;
	}
	nav a.active {
		color: var(--heading);
		border-bottom: 2px solid var(--heading);
	}
</style>
