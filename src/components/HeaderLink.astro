---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const normalizePath = (value: string) => {
	const withoutBase = value.replace(import.meta.env.BASE_URL, '/');
	const trimmed = withoutBase.replace(/\/+$/, '');
	return trimmed === '' ? '/' : trimmed;
};

const pathname = normalizePath(Astro.url.pathname);
const normalizedHref = normalizePath(href?.toString() ?? '/');
const subpath = pathname.match(/[^\/]+/g);
const isActive = normalizedHref === pathname || normalizedHref === '/' + (subpath?.[0] || '');
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
