---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const notes = (await getCollection('notes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// With Astro's base set to '/en/', all routes are prefixed with '/en/'
const createNoteUrl = (noteId) => `/en/notes/${noteId}/`;

const notesWithContent = await Promise.all(
	notes.map(async (note) => ({
		note,
		rendered: await render(note),
	})),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			section {
				padding: 2em 0;
			}
			.page-title {
				font-size: 10px;
				color: var(--muted);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 1.5em;
			}
			.feed {
				display: grid;
				gap: 2rem;
			}
			article {
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--border);
			}
			article:last-child {
				border-bottom: none;
				padding-bottom: 0;
			}
			.note-meta {
				font-size: 10px;
				color: var(--muted);
				letter-spacing: 0.06em;
				text-transform: uppercase;
				margin-bottom: 0.4em;
			}
			.title {
				font-family: 'Lora', Georgia, serif;
				font-size: 1.1em;
				font-weight: 700;
				color: var(--heading);
				line-height: 1.35;
				margin: 0 0 0.8em;
			}
			.note-body :global(p) {
				font-size: 0.95em;
				line-height: 1.75;
				margin: 0 0 1em;
			}
			.note-body :global(p:last-child) {
				margin-bottom: 0;
			}
			.note-link {
				display: inline-block;
				margin-top: 1rem;
				font-size: 0.9em;
				color: var(--muted);
				text-decoration: none;
			}
			.note-link:hover {
				color: var(--heading);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<p class="page-title">Notes</p>
				<div class="feed">
					{
						notesWithContent.map(({ note, rendered }) => {
							const noteTitle = note.data.title ?? '';
							const { Content } = rendered;

							return (
								<article>
									<p class="note-meta">
										<FormattedDate date={note.data.pubDate} />
									</p>
									{noteTitle && <h2 class="title">{noteTitle}</h2>}
									<div class="note-body">
										<Content />
									</div>
									<a class="note-link" href={createNoteUrl(note.id)}>
										Permalink
									</a>
								</article>
							);
						})
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
