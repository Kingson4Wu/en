---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Search" description={SITE_DESCRIPTION} />
		<link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />
		<style>
			.search-page {
				padding: 3em 0;
			}
			.page-title {
				font-size: 10px;
				color: var(--muted);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 1.5em;
			}
			/* Override Pagefind UI to match site theme */
			:root {
				--pagefind-ui-scale: 0.9;
				--pagefind-ui-primary: var(--heading);
				--pagefind-ui-text: var(--text);
				--pagefind-ui-background: var(--bg);
				--pagefind-ui-border: var(--border);
				--pagefind-ui-tag: var(--border);
				--pagefind-ui-border-width: 1px;
				--pagefind-ui-border-radius: 6px;
				--pagefind-ui-image-border-radius: 6px;
				--pagefind-ui-font: 'Lora', Georgia, serif;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="search-page">
				<p class="page-title">Search</p>
				<div id="search"></div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script is:inline define:vars={{ base }}>
	window.addEventListener('DOMContentLoaded', () => {
		const s = document.createElement('script');
		s.src = base + 'pagefind/pagefind-ui.js';
		s.onload = () => {
			new PagefindUI({ element: '#search', baseUrl: base, showSubResults: true });
		};
		s.onerror = () => {
			document.getElementById('search').innerHTML =
				'<p style="color:var(--muted);font-size:0.9em">Search not available in dev mode. Run <code>npm run build</code> then <code>npm run preview</code> to test.</p>';
		};
		document.head.appendChild(s);
	});
</script>
