---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { collectTagStats } from '../../utils/tags';

const posts = await getCollection('blog');
const tags = collectTagStats(posts);

function getWeightClass(count: number, counts: number[]) {
	const uniqueCounts = [...new Set(counts)].sort((a, b) => a - b);
	if (uniqueCounts.length === 1) return 'weight-3';

	const rank = uniqueCounts.indexOf(count);
	const bands = Math.min(5, uniqueCounts.length);
	const band = Math.floor((rank / (uniqueCounts.length - 1)) * (bands - 1)) + 1;
	return `weight-${band}`;
}

const counts = tags.map((tag) => tag.count);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Tags" description={SITE_DESCRIPTION} />
		<style>
			section {
				padding: 2em 0;
			}
			.page-title {
				font-size: 10px;
				color: var(--muted);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 1.5em;
			}
			.tag-cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75em;
				align-items: baseline;
			}
			.tag-link {
				text-decoration: none;
				color: var(--heading);
				border-bottom: 1px solid transparent;
				padding-bottom: 0.1em;
			}
			.tag-link:hover {
				color: var(--text-muted);
				border-bottom-color: var(--muted);
			}
			.tag-count {
				font-size: 0.7em;
				color: var(--muted);
				margin-left: 0.3em;
				vertical-align: super;
			}
			.weight-1 {
				font-size: 0.95rem;
			}
			.weight-2 {
				font-size: 1.05rem;
			}
			.weight-3 {
				font-size: 1.15rem;
			}
			.weight-4 {
				font-size: 1.3rem;
			}
			.weight-5 {
				font-size: 1.45rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<p class="page-title">Tags</p>
				<div class="tag-cloud">
					{
						tags.map((tag) => (
							<a class={`tag-link ${getWeightClass(tag.count, counts)}`} href={`/en/tags/${tag.slug}/`}>
								{tag.tag}
								<span class="tag-count">{tag.count}</span>
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
